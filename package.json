{
    "name": "pickles",
    "version": "0.0.1-dev",
    "private": true,
    "type": "module",
    "scripts": {
        "format": "npm run format:prettier && npm run format:kotlin",
        "format:check": "npm run format:prettier:check && npm run format:kotlin:check",
        "format:prettier": "prettier --write \"**/*.{js,mjs,ts,json,md,yml,yaml}\"",
        "format:prettier:check": "prettier --check \"**/*.{js,mjs,ts,json,md,yml,yaml}\"",
        "format:kotlin": "gradle -p pickles-intellij-plugin spotlessApply --no-configuration-cache",
        "format:kotlin:check": "gradle -p pickles-intellij-plugin spotlessCheck --no-configuration-cache"
    },
    "devDependencies": {
        "prettier": "3.8.3"
    }
}

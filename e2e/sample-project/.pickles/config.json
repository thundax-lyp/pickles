{
    "version": 1,
    "agent": "codex",
    "bind": {
        "agentsFile": "AGENTS.md",
        "enabled": true
    },
    "hook": {
        "protocol": "http"
    },
    "rules": {
        "archunit": {
            "enabled": true,
            "command": ""
        },
        "eslint": {
            "enabled": true,
            "command": "npm run lint"
        },
        "scripts": []
    },
    "problemBoard": {
        "aggregation": "workspace"
    }
}
